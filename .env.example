# これをコピーして .env を作り、実際のキーを入れてください（.env は外部に出さない）

# Stripe（読み取り専用キー推奨。rk_live_... または sk_live_...）
STRIPE_API_KEY=

# --- 以下はフェーズ1以降で使います（今は空でOK） ---
# Meta広告
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google（GA4 / Search Console 共用のサービスアカウントJSONのパス）
GOOGLE_APPLICATION_CREDENTIALS=
GA4_PROPERTY_ID=
SEARCH_CONSOLE_SITE_URL=

# BASE
BASE_CLIENT_ID=
BASE_CLIENT_SECRET=
BASE_REFRESH_TOKEN=
